<Project>
  <PropertyGroup>
    <DefineConstants>$(DefineConstants);RESONITE_MOD</DefineConstants>

    <ResoniteUseMonkeyLoaderCore Condition="'$(ResoniteUseMonkeyLoaderCore)' == ''">false</ResoniteUseMonkeyLoaderCore>
    <ResoniteUseMonkeyLoaderCore Condition="'$(ResoniteTargetModLoader)' == 'MonkeyLoader'">false</ResoniteUseMonkeyLoaderCore>

    <ResoniteHasIgnoreAccessChecksAttribute Condition="'$(ResoniteHasIgnoreAccessChecksAttribute)' == ''">false</ResoniteHasIgnoreAccessChecksAttribute>
    <ResoniteHasIgnoreAccessChecksAttribute Condition="'$(ResoniteUseMonkeyLoaderCore)' == 'true'">true</ResoniteHasIgnoreAccessChecksAttribute>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="$(MSBuildThisFileDirectory)../include/IgnoresAccessChecksToAttribute.cs" Visible="false"
             Condition="'$(ResoniteHasIgnoreAccessChecksAttribute)' != 'true'" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="MicroUtils.HarmonyAnalyzers" Version="$(MicroUtils_HarmonyAnalyzers_Version)">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>

    <PackageReference Include="MonkeyLoader.GamePacks.Resonite.Core" Version="$(MonkeyLoader_GamePacks_Resonite_Version)"
                      Condition="'$(ResoniteTargetModLoader)' != 'MonkeyLoader' AND '$(ResoniteTarget)' != 'renderite' AND '$(ResoniteUseMonkeyLoaderCore)' == 'true'" />
  </ItemGroup>

  <Import Project="Mod.MonkeyLoader.targets" Condition="'$(ResoniteTargetModLoader)' == 'MonkeyLoader'" />
  <Import Project="Mod.MonkeyLoader.ResoniteModLoader.targets" Condition="'$(ResoniteTargetModLoader)' == 'ResoniteModLoader'" />
  <Import Project="Mod.ResoniteModLoader.targets" Condition="'$(ResoniteTargetModLoader)' == 'ResoniteModLoaderStandalone'" />
  <Import Project="Mod.BepisLoader.targets" Condition="'$(ResoniteTargetModLoader)' == 'BepisLoader'" />
</Project>