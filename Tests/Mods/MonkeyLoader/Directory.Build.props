<Project>
  <!-- Recursively import Directory.Build.props in folders above -->
  <Import Project="$([MSBuild]::GetPathOfFileAbove('$(MSBuildThisFile)', '$(MSBuildThisFileDirectory)../'))" />
  
  <PropertyGroup>
    <ResoniteTargetModLoader>MonkeyLoader</ResoniteTargetModLoader>
  </PropertyGroup>
</Project>